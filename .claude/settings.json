{
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/validate-workspace.sh \"$TOOL_INPUT\"",
            "description": "Warns when Bash commands target wrong working directory"
          }
        ]
      }
    ]
  }
}
